---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'tr' } = Astro.props;
const t = useTranslations(lang);
const featured = t('criteria.featured') as { icon: string; title: string; desc: string };
const standards = t('criteria.standards') as { icon: string; title: string; desc: string }[];
---

<section class="py-14 md:py-24 bg-surface-container-low" id="criteria">
  <div class="max-w-7xl mx-auto px-gutter md:px-margin">
    <div class="text-center mb-12 md:mb-16 reveal">
      <span class="text-xs font-medium text-secondary tracking-wider uppercase mb-2 block">{t('criteria.eyebrow')}</span>
      <h2 class="font-headline text-4xl font-bold text-on-surface mb-4">{t('criteria.title')}</h2>
      <p class="font-body text-base text-on-surface-variant max-w-2xl mx-auto">
        {t('criteria.intro')}
      </p>
    </div>

    <!-- Featured spotlight -->
    <div class="reveal relative rounded-2xl bg-surface border border-outline-variant shadow-sm overflow-hidden">
      <span class="material-symbols-outlined absolute -right-6 -bottom-10 text-[220px] text-secondary/5 select-none pointer-events-none leading-none">{featured.icon}</span>
      <div class="relative grid md:grid-cols-[auto_1fr] gap-8 items-center p-8 md:p-12">
        <div class="w-20 h-20 md:w-24 md:h-24 rounded-2xl bg-secondary-container/25 text-secondary flex items-center justify-center flex-shrink-0">
          <span class="material-symbols-outlined text-5xl md:text-6xl">{featured.icon}</span>
        </div>
        <div>
          <h3 class="font-headline text-2xl md:text-3xl font-bold text-on-surface mb-4">{featured.title}</h3>
          <p class="font-body text-base text-on-surface-variant leading-relaxed max-w-2xl">{featured.desc}</p>
        </div>
      </div>
    </div>

    <!-- Supporting standards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-6">
      {standards.map((s, i) => (
        <div
          class="reveal group pt-6 border-t-2 border-outline-variant hover:border-secondary transition-colors duration-300"
          style={`--reveal-delay:${180 + i * 120}ms`}
        >
          <div class="flex items-center gap-3 mb-3">
            <span class="w-10 h-10 rounded-lg bg-secondary-container/20 text-secondary flex items-center justify-center transition-transform duration-300 group-hover:scale-110">
              <span class="material-symbols-outlined text-xl">{s.icon}</span>
            </span>
            <h4 class="font-headline text-lg font-semibold text-on-surface">{s.title}</h4>
          </div>
          <p class="font-body text-sm text-on-surface-variant leading-relaxed">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 600ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }
  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const initCriteria = () => {
    const section = document.getElementById('criteria');
    if (!section) return;

    const reveals = Array.from(section.querySelectorAll<HTMLElement>('.reveal'));

    if (!('IntersectionObserver' in window)) {
      reveals.forEach((el) => el.classList.add('is-visible'));
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -60px 0px' }
    );

    reveals.forEach((el) => io.observe(el));
  };

  initCriteria();
</script>
