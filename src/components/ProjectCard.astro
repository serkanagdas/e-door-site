---
import { type Project, getProjectHref } from '../data/projects';
import { type Lang } from '../i18n/utils';

interface Props {
  project: Project;
  lang?: Lang;
}

const { project, lang = 'tr' } = Astro.props;
const href = getProjectHref(project.slug, lang);
---

<a
  href={href}
  class="reveal group relative flex flex-col overflow-hidden rounded-2xl border border-outline-variant bg-surface shadow-sm transition-all duration-300 hover:border-secondary hover:shadow-lg hover:-translate-y-1"
>
  <!-- İkon + Kategori -->
  <div class="relative p-7 pb-0">
    <div class="flex items-center justify-between mb-5">
      <div class="w-14 h-14 rounded-xl bg-secondary-fixed flex items-center justify-center text-on-secondary-fixed group-hover:scale-110 transition-transform">
        <span class="material-symbols-outlined text-[32px]">{project.icon}</span>
      </div>
      <span class="px-3 py-1 rounded-full bg-secondary-container/15 text-secondary text-[10px] font-semibold tracking-wide uppercase">
        {project.category[lang]}
      </span>
    </div>
  </div>

  <!-- İçerik -->
  <div class="flex flex-col flex-1 px-7 pb-7">
    <h3 class="font-headline text-xl font-bold text-on-surface mb-1">{project.name[lang]}</h3>
    <p class="font-headline text-sm text-secondary font-medium mb-3">{project.subtitle[lang]}</p>
    <p class="font-body text-sm text-on-surface-variant leading-relaxed mb-5 flex-1 line-clamp-3">
      {project.summary[lang]}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-1.5 mb-5">
      {project.tags.slice(0, 4).map((tag) => (
        <span class="px-2 py-1 rounded-md bg-surface-container text-[10px] font-medium text-on-surface-variant">
          {tag}
        </span>
      ))}
    </div>

    <!-- CTA -->
    <div class="flex items-center gap-2 text-secondary text-sm font-semibold">
      <span class="material-symbols-outlined text-lg">arrow_forward</span>
    </div>
  </div>

  <!-- Hover accent bar -->
  <div class="absolute bottom-0 left-0 right-0 h-1 bg-secondary scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></div>
</a>
