---
import { useTranslations, getNavLinks, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'tr' } = Astro.props;
const t = useTranslations(lang);
const paths = getNavLinks(lang);

const navLinks = [
  { key: 'home', href: paths.home },
  { key: 'about', href: paths.about },
  { key: 'projects', href: paths.projects },
  { key: 'contact', href: paths.contact },
];

const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) => currentPath === (href.replace(/\/+$/, '') || '/');
const isHome = currentPath === '/' || currentPath === '/en';
---

<nav id="site-nav" data-on-sky={isHome ? 'true' : 'false'} class="fixed top-0 w-full z-50 transition-all duration-300 ease-in-out">
  <div class="flex items-center justify-between px-gutter md:px-margin py-4 max-w-7xl mx-auto">
    <a class="flex-shrink-0" href={paths.home}>
      <img alt="E-DOOR Logo" class="nav-logo h-8 w-auto transition-[filter] duration-300" src="/images/logo.png" />
    </a>
    <div class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <a
          class:list={[
            'nav-text relative px-4 py-2 rounded-lg font-body text-sm transition-colors duration-200',
            isActive(link.href)
              ? 'text-secondary font-semibold'
              : 'text-on-surface-variant hover:text-secondary',
          ]}
          href={link.href}
        >
          {t(`nav.${link.key}`)}
          {isActive(link.href) && (
            <span class="nav-active-bar absolute left-4 right-4 -bottom-0.5 h-0.5 bg-secondary rounded-full"></span>
          )}
        </a>
      ))}
    </div>
    <div class="flex items-center gap-2">
      <a
        class="nav-quote-btn hidden md:inline-flex items-center justify-center px-6 py-2.5 rounded-lg bg-secondary text-on-secondary text-xs font-semibold hover:bg-on-secondary-container transition-colors"
        href={paths.contact}
      >
        {t('nav.quote')}
      </a>
      <button
        id="menu-toggle"
        aria-label={t('nav.menuAria')}
        aria-expanded="false"
        class="nav-menu-icon md:hidden p-2 text-on-surface"
      >
        <span class="material-symbols-outlined nav-text" id="menu-icon">menu</span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-surface-variant bg-surface/95 backdrop-blur-md">
    <div class="px-gutter py-4 flex flex-col gap-1 max-w-7xl mx-auto">
      {navLinks.map((link) => (
        <a
          class:list={[
            'mobile-link font-body text-base rounded-lg px-4 py-3 transition-colors',
            isActive(link.href)
              ? 'text-secondary font-semibold bg-secondary-container/15'
              : 'text-on-surface-variant hover:text-secondary hover:bg-surface-container',
          ]}
          href={link.href}
        >
          {t(`nav.${link.key}`)}
        </a>
      ))}
      <a
        class="mobile-link inline-flex items-center justify-center mt-2 px-6 py-3 rounded-lg bg-secondary text-on-secondary text-sm font-semibold"
        href={paths.contact}
      >
        {t('nav.quote')}
      </a>
    </div>
  </div>
</nav>

<script>
  const initNav = () => {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const icon = document.getElementById('menu-icon');
    if (!toggle || !menu || !icon) return;

    const close = () => {
      menu.classList.add('hidden');
      icon.textContent = 'menu';
      toggle.setAttribute('aria-expanded', 'false');
    };

    const open = () => {
      menu.classList.remove('hidden');
      icon.textContent = 'close';
      toggle.setAttribute('aria-expanded', 'true');
    };

    toggle.addEventListener('click', () => {
      menu.classList.contains('hidden') ? open() : close();
    });

    menu.querySelectorAll('.mobile-link').forEach((link) => {
      link.addEventListener('click', close);
    });

    const desktopMQ = window.matchMedia('(min-width: 768px)');
    desktopMQ.addEventListener('change', (e) => {
      if (e.matches) close();
    });
  };

  document.addEventListener('astro:page-load', initNav);

  // Scroll-aware navbar: blends with the sky at the very top of the homepage,
  // then animates into a solid bar as the user scrolls down.
  const NAV_THRESHOLD = 80;
  const updateNavTop = () => {
    const nav = document.getElementById('site-nav');
    if (!nav || nav.dataset.onSky !== 'true') return;
    if (window.scrollY <= NAV_THRESHOLD) nav.classList.add('nav-top');
    else nav.classList.remove('nav-top');
  };
  let navScrollBound = false;
  const bindNavScroll = () => {
    updateNavTop();
    if (navScrollBound) return;
    navScrollBound = true;
    window.addEventListener('scroll', updateNavTop, { passive: true });
  };
  document.addEventListener('astro:page-load', bindNavScroll);
</script>
