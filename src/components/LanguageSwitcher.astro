---
import { getLangFromUrl, getCounterpartUrl, languages, type Lang } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const counterpartUrl = getCounterpartUrl(Astro.url.pathname);
const counterpartLang: Lang = lang === 'tr' ? 'en' : 'tr';
---

<a
  href={counterpartUrl}
  aria-label={lang === 'tr' ? 'Switch to English' : 'Türkçe\'ye geç'}
  class="inline-flex items-center gap-1.5 text-on-surface-variant hover:text-secondary transition-colors"
>
  <span class="material-symbols-outlined text-xl">language</span>
  <span class="text-sm font-medium uppercase">{counterpartLang}</span>
</a>
