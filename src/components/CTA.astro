---
import { useTranslations, getNavLinks, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'tr' } = Astro.props;
const t = useTranslations(lang);
const paths = getNavLinks(lang);
---

<section id="cta" class="bg-background py-14 md:py-24">
  <div class="mx-auto max-w-5xl px-gutter md:px-margin">
    <div class="reveal relative overflow-hidden rounded-[2rem] bg-secondary px-8 py-14 text-center shadow-lg md:px-16 md:py-20">
      <div class="absolute inset-0 hero-pattern opacity-10"></div>
      <span class="material-symbols-outlined absolute -right-8 -top-8 select-none text-[220px] leading-none text-on-secondary/10">rocket_launch</span>
      <div class="relative">
        <h2 class="mb-4 font-headline text-3xl font-bold text-on-secondary md:text-4xl">{t('cta.title')}</h2>
        <p class="mx-auto mb-8 max-w-xl font-body text-base text-on-secondary/80">
          {t('cta.text')}
        </p>
        <a
          href={paths.contact}
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-on-secondary px-8 py-3 text-sm font-semibold text-secondary shadow-md transition-all hover:scale-105"
        >
          {t('cta.button')}
          <span class="material-symbols-outlined text-base">arrow_forward</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 600ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }
  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const initCTA = () => {
    const section = document.getElementById('cta');
    if (!section) return;

    const reveals = section.querySelectorAll('.reveal');
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
    );
    reveals.forEach((el) => io.observe(el));
  };

  document.addEventListener('astro:page-load', initCTA);
</script>
