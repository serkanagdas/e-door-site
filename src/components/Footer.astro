---

<footer class="w-full border-t border-outline-variant bg-surface-container-highest py-5">
  <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-5 px-gutter md:px-margin">
    <div class="flex items-center gap-4">
      <img alt="E-DOOR Logo" class="h-9 w-auto opacity-80 mix-blend-multiply" src="/images/logo-footer.png" />
      <p class="font-body text-xs text-on-surface-variant sm:text-sm">
        {t('footer.copyright')}
      </p>
    </div>

    <div class="flex items-center gap-5">
      <div class="flex items-center gap-3">
        {socials.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={social.label}
            class="flex h-10 w-10 items-center justify-center rounded-lg border border-outline-variant text-on-surface-variant transition-all hover:border-secondary hover:text-secondary"
            set:html={social.svg}
          />
        ))}
      </div>
      <LanguageSwitcher />
    </div>
  </div>
</footer>
