---
import { useTranslations, type Lang } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
const t = useTranslations(lang);

