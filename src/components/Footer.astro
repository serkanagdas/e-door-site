---
import { useTranslations, getNavLinks, type Lang } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang?: Lang;
}
const { lang = 'tr' } = Astro.props;
const t = useTranslations(lang);
const paths = getNavLinks(lang);

const quickLinks = [
  { href: paths.about, label: t('nav.about') },
  { href: paths.projects, label: t('nav.projects') },
  { href: paths.contact, label: t('nav.contact') },
];

const serviceLinks = (t('footer.serviceLinks') as string[]).map((label) => ({ href: '#', label }));
const legalLinks = (t('footer.legalLinks') as string[]).map((label) => ({ href: '#', label }));
---

<footer class="bg-surface-container-highest w-full pt-12 md:pt-16 pb-8 border-t border-outline-variant">
  <div class="max-w-7xl mx-auto px-gutter md:px-margin">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 md:gap-12 mb-12">
      <div class="col-span-1 md:col-span-1">
        <img alt="E-DOOR Logo" class="h-10 w-auto mb-6 opacity-80 mix-blend-multiply" src="/images/logo-footer.png" />
        <p class="font-body text-sm text-on-surface-variant">
          {t('footer.tagline')}
        </p>
      </div>
      <div>
        <h4 class="font-headline text-lg font-semibold text-on-surface mb-4">{t('footer.quickLinks')}</h4>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li><a class="font-body text-sm text-on-surface-variant hover:text-secondary transition-colors" href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-headline text-lg font-semibold text-on-surface mb-4">{t('footer.services')}</h4>
        <ul class="space-y-3">
          {serviceLinks.map((link) => (
            <li><a class="font-body text-sm text-on-surface-variant hover:text-secondary transition-colors" href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-headline text-lg font-semibold text-on-surface mb-4">{t('footer.legal')}</h4>
        <ul class="space-y-3">
          {legalLinks.map((link) => (
            <li><a class="font-body text-sm text-on-surface-variant hover:text-secondary transition-colors" href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
    <div class="border-t border-outline-variant pt-8 flex flex-col md:flex-row items-center justify-between">
      <p class="font-body text-sm text-on-surface-variant">
        {t('footer.copyright')}
      </p>
      <div class="flex items-center space-x-4 mt-4 md:mt-0">
        <LanguageSwitcher />
      </div>
    </div>
  </div>
</footer>
