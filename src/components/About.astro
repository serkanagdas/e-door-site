---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'tr' } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-14 md:py-24 bg-background" id="about">
  <div class="max-w-7xl mx-auto px-gutter md:px-margin">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-16 items-center">
      <div>
        <div class="w-20 h-1 bg-secondary mb-8 rounded-full"></div>
        <h2 class="font-headline text-4xl font-semibold text-on-surface mb-6 leading-tight">
          {t('about.titleA')}<br />{t('about.titleB')}
        </h2>
        <p class="font-body text-base text-on-surface-variant mb-6 leading-relaxed">
          {t('about.p1')}
        </p>
        <p class="font-body text-base text-on-surface-variant mb-6 leading-relaxed">
          {t('about.p2')}
        </p>
        <p class="font-body text-base text-on-surface-variant leading-relaxed">
          {t('about.p3')}
        </p>
      </div>
      <div class="relative">
        <div class="absolute -inset-4 bg-secondary-container/20 rounded-[2rem] transform rotate-3"></div>
        <img class="relative rounded-2xl shadow-lg w-full h-72 sm:h-96 md:h-[500px] object-cover" src="/images/team.jpg" alt={t('about.imgAlt')} />
        <div class="absolute -bottom-8 left-0 md:-left-8 glass-card p-6 rounded-xl shadow-lg w-60 sm:w-64">
          <div class="flex items-center gap-4 mb-2">
            <div class="w-10 h-10 rounded-full bg-secondary-container flex items-center justify-center text-on-secondary-container">
              <span class="material-symbols-outlined">rocket_launch</span>
            </div>
            <div>
              <h4 class="font-headline text-xl font-semibold text-on-surface">{t('about.statValue')}</h4>
              <p class="text-xs font-medium text-on-surface-variant">{t('about.statLabel')}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
