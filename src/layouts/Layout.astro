---
import '../styles/global.css';
import interWoff2 from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2';
import geistWoff2 from '@fontsource-variable/geist/files/geist-latin-wght-normal.woff2';
import msWoff2 from '@fontsource-variable/material-symbols-outlined/files/material-symbols-outlined-latin-full-normal.woff2';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  title?: string;
  description?: string;
}

const {
  title = t('meta.defaultTitle'),
  description = t('meta.defaultDescription'),
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
  <html lang={lang} class="scroll-smooth overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <ClientRouter />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preload" href={interWoff2} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={geistWoff2} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={msWoff2} as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
    <script is:inline data-astro-rerun>
      (function () {
        var html = document.documentElement;
        function ready() { html.classList.add('icon-font-ready'); }
        if (!document.fonts) { ready(); return; }
        if (document.fonts.check("24px 'Material Symbols Outlined Variable'")) { ready(); return; }
        document.fonts.load("24px 'Material Symbols Outlined Variable'").then(ready, ready);
      })();
    </script>
    <script>
      // SPA (view-transition) geçişlerinde, ekran içindeki .reveal öğelerini
      // snapshot alınmadan HEMEN görünür yap. Aksi halde geçiş cross-fade'i
      // hero başlığını "gizli" yakalıyor; ardından reveal tekrar oynuyor ve
      // sayfa iki kere açılıyormuş / hero başa dönüyormuş gibi görünüyordu.
      document.addEventListener('astro:after-swap', () => {
        const vh = window.innerHeight;
        document.querySelectorAll('.reveal').forEach((el) => {
          if (el.classList.contains('is-visible')) return;
          const rect = el.getBoundingClientRect();
          const inViewport = rect.top < vh && rect.bottom > 0;
          if (!inViewport) return;
          el.style.transition = 'none';
          el.classList.add('is-visible');
          requestAnimationFrame(() =>
            requestAnimationFrame(() => {
              el.style.transition = '';
            })
          );
        });
      });
    </script>
  </head>
  <body class="bg-background text-on-background font-body antialiased overflow-x-hidden selection:bg-secondary-container selection:text-on-secondary-container">
    <Navbar lang={lang} />
    <main class="pt-[72px]">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
