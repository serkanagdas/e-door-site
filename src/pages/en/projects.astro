---
import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const project = {
  name: t('projectsPage.project.name'),
  subtitle: t('projectsPage.project.subtitle'),
  category: t('projectsPage.project.category'),
  client: t('projectsPage.project.client'),
  year: t('projectsPage.project.year'),
  summary: t('projectsPage.project.summary'),
  tags: t('projectsPage.project.tags') as string[],
  stats: t('projectsPage.project.stats') as { value: string; label: string }[],
  cardTag: t('projectsPage.project.cardTag'),
};

const features = t('projectsPage.features') as { icon: string; title: string; desc: string }[];
const screenshots = t('projectsPage.screenshots') as { src: string; alt: string; title: string; desc: string; icon: string }[];
const techStack = t('projectsPage.techStack') as { category: string; icon: string; items: { name: string; desc: string }[] }[];
const departments = t('projectsPage.departments') as string[];

const title = t('projectsPage.title');
---

<Layout title={`${t('projectsPage.metaTitle')} | E-DOOR`} description={t('projectsPage.metaDesc')}>

  <!-- ==================== HERO ==================== -->
  <section class="relative overflow-hidden bg-surface-container-lowest">
    <div class="absolute inset-0 hero-pattern opacity-20"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-surface/30 to-background"></div>
    <div class="absolute inset-0 animated-grid"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-gutter md:px-margin py-16 md:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-[1.3fr_1fr] gap-12 items-center">
        <!-- Sol: Metin -->
        <div class="reveal">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-secondary-container/20 text-secondary text-xs font-semibold tracking-wide mb-5">
            <span class="material-symbols-outlined text-sm">verified</span>
            {project.category}
          </span>

          <h1 class="font-headline text-4xl md:text-6xl font-bold text-on-surface mb-3 leading-[1.1] tracking-tight">
            {project.name}
          </h1>
          <p class="font-headline text-lg md:text-xl text-on-surface-variant mb-6 font-medium">
            {project.subtitle}
          </p>

          <p class="font-body text-base text-on-surface-variant leading-relaxed max-w-2xl mb-8">
            {project.summary}
          </p>

          <!-- Etiketler -->
          <div class="flex flex-wrap gap-2 mb-8">
            {project.tags.map((tag) => (
              <span class="px-3 py-1.5 rounded-lg bg-surface border border-outline-variant text-xs font-medium text-on-surface-variant">
                {tag}
              </span>
            ))}
          </div>

          <!-- Meta bilgiler -->
          <div class="flex flex-wrap gap-x-8 gap-y-3 text-sm">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-secondary text-lg">apartment</span>
              <span class="text-on-surface-variant">{t('projectsPage.clientLabel')}</span>
              <span class="font-semibold text-on-surface">{project.client}</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-secondary text-lg">event</span>
              <span class="text-on-surface-variant">{t('projectsPage.yearLabel')}</span>
              <span class="font-semibold text-on-surface">{project.year}</span>
            </div>
          </div>
        </div>

        <!-- Sağ: Logo kartı -->
        <div class="reveal" style="--reveal-delay: 120ms;">
          <div class="relative">
            <div class="absolute -inset-3 bg-secondary-container/15 rounded-[2rem] transform -rotate-2"></div>
            <div class="relative glass-card rounded-[1.5rem] p-8 md:p-10 shadow-lg">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-16 h-16 rounded-2xl bg-secondary text-on-secondary flex items-center justify-center shadow-md">
                  <span class="material-symbols-outlined text-4xl">auto_stories</span>
                </div>
                <div>
                  <h3 class="font-headline text-2xl font-bold text-on-surface">{project.name}</h3>
                  <p class="text-xs text-on-surface-variant">{project.cardTag}</p>
                </div>
              </div>
              <div class="space-y-3">
                {project.stats.map((stat) => (
                  <div class="flex items-center justify-between py-2 border-b border-outline-variant/50 last:border-0">
                    <span class="text-sm text-on-surface-variant">{stat.label}</span>
                    <span class="font-headline text-lg font-bold text-secondary">{stat.value}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 w-full h-24 bg-gradient-to-t from-background to-transparent"></div>
  </section>

  <!-- ==================== EKRAN GÖRÜNTÜLERİ ==================== -->
  <section class="py-14 md:py-24 bg-background" id="screenshot">
    <div class="max-w-7xl mx-auto px-gutter md:px-margin">
      <div class="text-center mb-12 md:mb-16">
        <span class="text-xs font-medium text-secondary tracking-wider uppercase mb-2 block">{t('projectsPage.screensEyebrow')}</span>
        <h2 class="font-headline text-4xl font-bold text-on-surface">{t('projectsPage.screensTitle')}</h2>
        <p class="mt-3 font-body text-base text-on-surface-variant max-w-2xl mx-auto">
          {t('projectsPage.screensText')}
        </p>
      </div>

      <div class="space-y-12 md:space-y-16">
        {screenshots.map((shot, i) => (
          <div class:list={['reveal grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center', i % 2 === 1 && 'lg:grid-flow-dense']}>
            <!-- Görsel -->
            <div class:list={['relative', i % 2 === 1 && 'lg:col-start-2']}>
              <div class="absolute -inset-3 bg-secondary-container/15 rounded-[1.5rem] transform rotate-1"></div>
              <div class="shot-frame relative rounded-xl overflow-hidden shadow-xl border border-outline-variant bg-surface-container-high">
                <img
                  src={shot.src}
                  alt={shot.alt}
                  loading="lazy"
                  class="shot-img relative z-10 block w-full h-auto"
                  data-placeholder={shot.icon}
                />
                <div class="shot-placeholder absolute inset-0 z-20 flex flex-col items-center justify-center bg-gradient-to-br from-secondary-container/20 to-surface-container-highest text-center px-6 min-h-[300px] md:min-h-[400px]">
                  <div class="w-20 h-20 rounded-2xl bg-secondary/10 text-secondary flex items-center justify-center mb-4">
                    <span class="material-symbols-outlined text-5xl">{shot.icon}</span>
                  </div>
                  <p class="font-headline text-sm font-semibold text-on-surface-variant mb-1">{shot.title}</p>
                  <p class="text-xs text-on-surface-variant/70 max-w-xs">{t('projectsPage.shotPlaceholder')}</p>
                </div>
              </div>
            </div>
            <!-- Açıklama -->
            <div>
              <div class="w-12 h-1 bg-secondary mb-6 rounded-full"></div>
              <h3 class="font-headline text-2xl md:text-3xl font-bold text-on-surface mb-4">{shot.title}</h3>
              <p class="font-body text-base text-on-surface-variant leading-relaxed">{shot.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== ÖZELLİKLER ==================== -->
  <section class="py-14 md:py-24 bg-surface-container-low" id="features">
    <div class="max-w-7xl mx-auto px-gutter md:px-margin">
      <div class="text-center mb-12 md:mb-16">
        <span class="text-xs font-medium text-secondary tracking-wider uppercase mb-2 block">{t('projectsPage.featuresEyebrow')}</span>
        <h2 class="font-headline text-4xl font-bold text-on-surface">{t('projectsPage.featuresTitle')}</h2>
        <p class="mt-3 font-body text-base text-on-surface-variant max-w-2xl mx-auto">
          {t('projectsPage.featuresText')}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {features.map((feature, i) => (
          <div
            class="reveal bg-surface rounded-xl p-7 shadow-sm border border-outline-variant hover:border-secondary hover:shadow-md transition-all group"
            style={`--reveal-delay: ${i * 60}ms;`}
          >
            <div class="w-14 h-14 rounded-lg bg-secondary-fixed flex items-center justify-center text-on-secondary-fixed mb-5 group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-[32px]">{feature.icon}</span>
            </div>
            <h3 class="font-headline text-lg font-semibold text-on-surface mb-3">{feature.title}</h3>
            <p class="font-body text-sm text-on-surface-variant leading-relaxed">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== TEKNİK ALTYAPI ==================== -->
  <section class="py-14 md:py-24 bg-background" id="tech">
    <div class="max-w-7xl mx-auto px-gutter md:px-margin">
      <div class="text-center mb-12 md:mb-16">
        <span class="text-xs font-medium text-secondary tracking-wider uppercase mb-2 block">{t('projectsPage.techEyebrow')}</span>
        <h2 class="font-headline text-4xl font-bold text-on-surface">{t('projectsPage.techTitle')}</h2>
        <p class="mt-3 font-body text-base text-on-surface-variant max-w-2xl mx-auto">
          {t('projectsPage.techText')}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {techStack.map((group, i) => (
          <div
            class="reveal rounded-2xl border border-outline-variant bg-surface p-6 shadow-sm"
            style={`--reveal-delay: ${i * 80}ms;`}
          >
            <div class="flex items-center gap-3 mb-5 pb-4 border-b border-outline-variant">
              <div class="w-11 h-11 rounded-xl bg-secondary-container/20 text-secondary flex items-center justify-center">
                <span class="material-symbols-outlined text-2xl">{group.icon}</span>
              </div>
              <h3 class="font-headline text-lg font-semibold text-on-surface">{group.category}</h3>
            </div>
            <ul class="space-y-4">
              {group.items.map((item) => (
                <li>
                  <div class="flex items-center gap-2 mb-0.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-secondary"></span>
                    <span class="font-headline text-sm font-semibold text-on-surface">{item.name}</span>
                  </div>
                  <p class="text-xs text-on-surface-variant pl-3.5">{item.desc}</p>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Departmanlar -->
      <div class="reveal mt-12">
        <div class="rounded-2xl border border-outline-variant bg-surface-container-low p-8 md:p-10">
          <div class="flex items-center gap-3 mb-6">
            <span class="material-symbols-outlined text-secondary text-2xl">account_tree</span>
            <h3 class="font-headline text-xl font-semibold text-on-surface">{t('projectsPage.departmentsTitle')}</h3>
          </div>
          <div class="flex flex-wrap gap-3">
            {departments.map((dept) => (
              <span class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-surface border border-outline-variant text-sm font-medium text-on-surface-variant">
                <span class="w-1.5 h-1.5 rounded-full bg-secondary/60"></span>
                {dept}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
  <CTA lang={lang} />

</Layout>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 600ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }
  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  // Reveal animasyonları
  const reveals = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  );
  reveals.forEach((el) => io.observe(el));

  // Ekran görüntüsü placeholder yönetimi: görsel yüklenirse placeholder gizlenir
  document.querySelectorAll<HTMLImageElement>('.shot-img').forEach((img) => {
    const frame = img.closest('.shot-frame');
    const placeholder = frame?.querySelector<HTMLElement>('.shot-placeholder');
    if (!frame || !placeholder) return;

    const showImg = () => {
      img.style.zIndex = '30';
      placeholder.style.display = 'none';
    };
    const showPlaceholder = () => {
      img.style.zIndex = '10';
      placeholder.style.display = 'flex';
    };

    if (img.complete && img.naturalWidth > 0) {
      showImg();
    } else {
      showPlaceholder();
    }
    img.addEventListener('load', showImg);
    img.addEventListener('error', showPlaceholder);
  });
</script>
