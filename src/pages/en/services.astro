---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getNavLinks } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const paths = getNavLinks(lang);

const title = t('servicesPage.metaTitle');
---

<Layout title={`${title} | E-DOOR`} description={t('servicesPage.metaDesc')}>
  <section class="min-h-[70vh] flex items-center justify-center bg-background px-gutter md:px-margin">
    <div class="text-center max-w-xl">
      <div class="w-16 h-16 rounded-2xl bg-secondary-container/20 text-secondary flex items-center justify-center mx-auto mb-6">
        <span class="material-symbols-outlined text-4xl">construction</span>
      </div>
      <h1 class="font-headline text-3xl md:text-4xl font-bold text-on-surface mb-4">{title}</h1>
      <p class="font-body text-base text-on-surface-variant mb-8">
        {t('servicesPage.text')}
      </p>
      <a href={paths.home} class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-secondary text-on-secondary text-sm font-semibold hover:bg-on-secondary-container transition-colors">
        <span class="material-symbols-outlined text-base">arrow_back</span>
        {t('servicesPage.backHome')}
      </a>
    </div>
  </section>
</Layout>
